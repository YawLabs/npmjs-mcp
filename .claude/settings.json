{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "command=\"$(jq -r '.tool_input.command // empty')\"; case \"$command\" in *\"git commit\"*) ;; *) exit 0 ;; esac; npx tsc --noEmit >&2 || exit 2",
            "timeout": 60,
            "statusMessage": "Type-checking before commit"
          }
        ]
      }
    ]
  }
}
